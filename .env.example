# SkillOS Configuration
# Copy this to .env and fill in your values

# ── Cloud API (DeepSeek) ──────────────────────────────────────
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# ── Role-based models (small for evolution, large for execution) ──
# SKILLOS_EVOLVER_MODEL=deepseek-v4-flash
# SKILLOS_EXECUTOR_MODEL=deepseek-v4-pro

# ── Marketplace ────────────────────────────────────────────────
# SKILLHUB_COMMISSION=0.20
# SKILLHUB_PRIVATE=false
# SKILLHUB_ADMIN_PASSWORD=admin123

# ── Local mode (Ollama, no API key needed) ─────────────────────
# Leave DEEPSEEK_API_KEY empty and SkillOS auto-switches to:
#   Base URL: http://localhost:11434/v1
#   Model: llama3.2 (pull first: ollama pull llama3.2)

# ── Official SkillsBench CI (optional) ───────────────────────
# GITHUB_TOKEN=ghp_...          # repo + workflow scope
# GITHUB_REPOSITORY=owner/SkillOS-python
# Periodic URL/knowledge refresh is ON by default (24h interval)
# SKILLOS_DISABLE_REFRESH=1
# SKILLOS_ENABLE_REFRESH=0
# SKILLOS_REFRESH_INTERVAL_HOURS=24
# File inbox watcher remains opt-in:
# SKILLOS_ENABLE_WATCHER=1
# SKILLOS_WATCHER_INTERVAL=3
